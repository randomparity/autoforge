# runner.toml — machine-local runner configuration
# Copy to runner.toml and fill in values for your environment.
# runner.toml is gitignored; never commit host-specific paths.
#
# This file contains framework-level settings only. For project-specific
# settings (testpmd, DTS, profiling, build options), see the example in
# projects/<project>/runner.toml.example and merge those sections here.

[runner]
# Runner phase: all (default), build, deploy, or test
phase = "all"

# Log level: debug, info, warning, error (also settable via LOG_LEVEL env var)
log_level = "info"

# Optional log file path (logs to both stdout and file when set)
# log_file = "/var/log/autoforge-runner.log"

# Seconds between polling for new requests
poll_interval = 30

[paths]
# Absolute path to the project source tree (e.g. DPDK)
dpdk_src = "/home/user/src/dpdk"

# Directory where build artifacts are written. Created automatically.
build_dir = "/tmp/dpdk-build"

[timeouts]
# Minutes to wait for a full build before aborting
build_minutes = 30

# Minutes to wait for test measurement to complete
test_minutes = 10
